# ============== Model Gateway 配置 ==============
# 一期 POC 支持 DeepSeek V4 Flash（默认）和 Qwen（阿里云 DashScope 兼容 OpenAI 模式）。
# 两个 Key 都为空时，Model Gateway 自动降级到本地确定性兜底模板（仍能完整跑通 Demo）。

# DeepSeek V4 Flash (POC 默认首选)
# 申请入口：https://platform.deepseek.com
DEEPSEEK_API_KEY="YOUR_DEEPSEEK_API_KEY"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# Qwen (阿里云 DashScope · OpenAI 兼容模式)
# 申请入口：https://dashscope.console.aliyun.com
# 可选模型：qwen-max / qwen-plus / qwen-turbo / qwen2.5-72b-instruct 等
QWEN_API_KEY="YOUR_QWEN_API_KEY"
QWEN_MODEL="qwen-max"
QWEN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# 强制指定 Provider：deepseek | qwen | auto（默认 auto，按上面优先级自动选）
MODEL_PROVIDER="auto"

# ============== 应用基础 ==============
PORT="9002"
APP_URL="http://localhost:9002"
